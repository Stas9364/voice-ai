# Gemini API key for Live API (server-only). Get it at https://aistudio.google.com/apikey
# Do not commit .env.local. Never use NEXT_PUBLIC_* in production — client uses POST /api/gemini-live.
GEMINI_API_KEY=your_api_key_here

# Optional: for direct WebSocket from browser (no route.ts). Dev/personal only — key is exposed to the client.
# If set, the app uses createLiveStreamDirectWS() instead of the API route.
# NEXT_PUBLIC_GEMINI_API_KEY=your_api_key_here
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=